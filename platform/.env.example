# Supabase — dev project (win-dev)
# Get these from: https://supabase.com/dashboard/project/<ref>/settings/database
# Use the "Session pooler" or "Transaction pooler" URL (port 6543) for runtime.
# Use the "Direct connection" URL (port 5432) for migrations.
DATABASE_URL=postgres://postgres:<password>@db.ujlkvaxlmrsvzgmlakgn.supabase.co:5432/postgres

# BetterAuth — generate with `npx @better-auth/cli secret` or `openssl rand -base64 32`
BETTER_AUTH_SECRET=<32-byte-base64>
BETTER_AUTH_URL=http://localhost:3001

# Plug and Pay — merchant PAT (never expose as NEXT_PUBLIC_*)
PLUGANDPAY_API_KEY=<jwt>

# Supabase public-safe keys (for client-side use)
NEXT_PUBLIC_SUPABASE_URL=https://ujlkvaxlmrsvzgmlakgn.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
