{
  "name": "win",
  "version": "1.0.0",
  "description": "Platform voor **WIN — Weerbaarheids Instituut Nederland**, het instituut van Reza voor *Weerbaarheidstherapie*: een integratieve aanpak die coaching combineert met psychofysieke training, gericht op professionals die hun weerbaarheid willen versterken.",
  "private": true,
  "workspaces": [
    "web",
    "platform",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=web",
    "dev:platform": "npm run dev --workspace=platform -- --port 3001",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace=web",
    "build:platform": "npm run build --workspace=platform",
    "lint": "npm run lint --workspaces --if-present",
    "stitch": "node scripts/stitch-generate.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamcoai/WIN.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/iamcoai/WIN/issues"
  },
  "homepage": "https://github.com/iamcoai/WIN#readme",
  "dependencies": {
    "@google/stitch-sdk": "^0.1.0"
  },
  "devDependencies": {
    "shadcn": "^4.4.0"
  }
}
